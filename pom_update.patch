diff --git a/commerce/interaction-api/pom.xml b/commerce/interaction-api/pom.xml
--- a/commerce/interaction-api/pom.xml	(revision ef117cff642817511ca1027c75be86297ee03a9b)
+++ b/commerce/interaction-api/pom.xml	(revision 865aa04092774ba72d431897af67e0786db31cbb)
@@ -73,4 +73,23 @@
             <version>3.1.2</version>
         </dependency>
     </dependencies>
+
+    <build>
+        <plugins>
+            <plugin>
+                <groupId>org.springframework.boot</groupId>
+                <artifactId>spring-boot-maven-plugin</artifactId>
+                <configuration>
+                    <mainClass>ru.yandex.practicum.commerce.interaction-api.Api</mainClass>
+                </configuration>
+                <executions>
+                    <execution>
+                        <goals>
+                            <goal>repackage</goal>
+                        </goals>
+                    </execution>
+                </executions>
+            </plugin>
+        </plugins>
+    </build>
 </project>
